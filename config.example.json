{
    "_comment": "dgmt configuration - Dylan's Google [Drive] Management Tool",

    "watch_paths": [
        "~/Obsidian"
    ],

    "rclone_remote": "dgmt",
    "rclone_dest": "Obsidian-Backup",
    "rclone_flags": ["--verbose"],

    "debounce_seconds": 30,
    "max_wait_seconds": 300,
    "health_check_interval": 60,

    "syncthing_api": "http://localhost:8384",
    "syncthing_api_key": null,

    "log_file": "~/.dgmt/dgmt.log",
    "log_level": "INFO",

    "restart_syncthing_on_failure": true,
    "syncthing_exe": "~/scoop/apps/syncthing/current/syncthing.exe",

    "calendar": {
        "enabled": false,
        "default_calendar_id": "primary",
        "default_view": "weekly",
        "color_rules": [
            {"pattern": "Meeting", "color_id": "7", "case_sensitive": false}
        ]
    }
}
